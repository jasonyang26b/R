library(tidyverse)
library(wooldridge)
library(car)
library(lmtest)
library(sandwich)
library(stargazer)
#?wage1
#names(wage1)
# To assemble multiple plots
library(gridExtra)
p1 <- ggplot(data = wage1, aes(x = exper)) +
geom_histogram(bins = 10) +
scale_x_continuous(breaks = seq(0,20,5))+
labs(title = "Most people have at leats 17 years of experience",
x = "Years of experience",
y = "Count")
p2 <- ggplot(data = wage1, aes(x = wage)) +
geom_histogram(bins = 10) +
scale_x_continuous(breaks = seq(0,30,2))+
labs(title = "Most people earn at most 14 ",
x = "Hourly wage",
y = "Count")
p3 <- ggplot(data = wage1, aes(x = exper, y = wage)) +
geom_point() +
geom_smooth(se = FALSE) +
labs(title = "A nonlinear association betwee wage and experience",
x = "Years of experience",
y = "Hourly wage")
p4 <- ggplot(data = wage1, aes(x = exper, y = lwage)) +
geom_point() +
geom_smooth(se = FALSE) +
labs(title = "A nonlinear association betwee log of wage and experience",
x = "Years of experience",
y = "Log Hourly wage")
grid.arrange(p1, p2,p3,p4, nrow = 2, ncol = 2)
e1 <- ggplot(data = wage1, aes(x = exper, y = wage)) +
geom_point() +
geom_smooth(se = FALSE) +
labs(
title = "Non-linear relationship between years of experiece and hourly wage",
x = "Years of experience",
y = "Average of hourly wage")
e2 <- ggplot(data = wage1, aes(x = tenure, y = wage)) +
geom_point() +
geom_smooth(se = FALSE) +
labs(
title = "Non-linear association between years of experiece and hourly wage",
x = "Years with current employer ",
y = "Average of hourly wage")
grid.arrange(e1, e2, nrow=1, ncol=2)
model_0 = lm( wage ~ factor(exper), data = wage1)
ggplot(data = wage1, aes(x = exper, y = model_0$fitted.values)) +
geom_point() +
labs(
title = "Fitted values v.s. exper",
x = "Exper",
y = "Fitted values")
model_1 <- lm(lwage ~ exper + tenure, data = wage1)
model_1 <- lm(lwage ~ exper + tenure, data = wage1)
model_1
coeftest(model_1, vcovHC(model_1))
model_2
model_2 <- lm(lwage ~ exper + I(exper^2) + tenure + I(tenure^2), data = wage1)
model_2
coeftest(model_2, vcovHC(model_2))
model_3 <- lm(lwage ~ female + exper + tenure + I(exper^2), data = wage1)
model_3
coeftest(model_3, vcovHC(model_3))
model_4 <- lm(lwage ~ female + exper + tenure + I(exper^2) + femal * exper, data=wage1)
model_4 <- lm(lwage ~ female + exper + tenure + I(exper^2) + female * exper, data=wage1)
model_4
coeftest(model_4)
model4 <- lm(lwage ~ female + exper + female*exper + I(exper^2)  + tenure
, data = wage1)
coeftest(model4, vcov = vcovHC)
model3 <- lm(lwage ~ female + exper  + tenure + I(exper^2) , data = wage1)
coeftest(model3, vcov = vcovHC)
se.model1 = coeftest(model1, vcov = vcovHC)[ , "Std. Error"]
model2 <- lm(lwage ~ exper + I(exper^2) + tenure + I(tenure^2) , data = wage1)
coeftest(model2, vcov = vcovHC)
model1 <- lm(lwage ~ exper + tenure , data = wage1)
coeftest(model1, vcov = vcovHC)
se.model1 = coeftest(model1, vcov = vcovHC)[ , "Std. Error"]
se.model2 = coeftest(model2, vcov = vcovHC)[ , "Std. Error"]
se.model3 = coeftest(model3, vcov = vcovHC)[ , "Std. Error"]
se.model4 = coeftest(model4, vcov = vcovHC)[ , "Std. Error"]
stargazer(model1, model2, model3, model4, type = "text", omit.stat = "f",
se = list(se.model1, se.model2, se.model3, se.model4),
star.cutoffs = c(0.05, 0.01, 0.001),
title = "Table 1: The relationship between hourly wage and years of experience")
