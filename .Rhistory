# To assemble multiple plots
library(gridExtra)
p1 <- ggplot(data = wage1, aes(x = exper)) +
geom_histogram(bins = 10) +
scale_x_continuous(breaks = seq(0,20,5))+
labs(title = "Most people have at leats 17 years of experience",x = "Years of experience",y = "Count")
p2 <- ggplot(data = wage1, aes(x = wage)) +
geom_histogram(bins = 10) +
scale_x_continuous(breaks = seq(0,30,2))+
labs(title = "Most people earn at most 14 ", x = "Hourly wage", y = "Count")
p3 <- ggplot(data = wage1, aes(x = exper, y = wage)) +
geom_point() +
geom_smooth(se = FALSE) +
labs(title = "A nonlinear association betwee wage and experience", x = "Years of experience", y = "Hourly wage")
p4 <- ggplot(data = wage1, aes(x = exper, y = lwage)) +
geom_point() +
geom_smooth(se = FALSE) +
labs(title = "A nonlinear association betwee log of wage and experience", x = "Years of experience", y = "Log Hourly wage")
grid.arrange(p1, p2,p3,p4, nrow = 2, ncol = 2)
